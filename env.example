# Server
PORT=3000
VERIFY_TOKEN=your_webhook_verify_token
PUBLIC_URL=https://your-app-url.onrender.com  # Required for keep-alive self-ping
CRON_SECRET=your_random_secret_string         # Required: protects /api/tick. Sent as the "x-cron-secret" header (not a query param) — configure cron-job.org with a custom header.

# WhatsApp (Meta Cloud API)
# Get from: https://developers.facebook.com → Your App → WhatsApp → API Setup
MY_PHONE_NUMBER=54xxxxxxxxxx
PHONE_NUMBER_ID=your_phone_number_id
ACCESS_TOKEN=your_permanent_access_token
WEBHOOK_APP_SECRET=your_meta_app_secret   # App Dashboard → Settings → Basic → App Secret. REQUIRED — the server refuses to start without this.

# Message Template — lets Kael deliver reminders/messages outside the 24h
# customer-service window (long-term reminders, and messages to third-party
# contacts who've never messaged Kael). Create this template first in
# Meta Business Manager → WhatsApp Manager → Message Templates:
#   Name:      kael_notification (or whatever you name it — must match below)
#   Category:  Utility
#   Language:  Spanish (Argentina) — es_AR
#   Body:      {{1}}
# Wait for Meta to approve it (usually minutes to a few hours), then set:
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=es_AR

# Supabase
# Get from: https://supabase.com → Project Settings → API
# Use the SERVICE_ROLE key (not the anon/public key). Row Level Security is
# enabled on every table (see supabase/rls.sql); the service_role key is the
# only one meant to bypass it. Never expose this key to a browser/client.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key

# AI — Tier 1 & 2
# Get from: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key

# AI — Tier 3 fallback
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# AI — Tier 4 fallback (PAID — GPT-4o-mini via OpenRouter)
# Leave this BLANK to guarantee $0 spend. If it's empty, Tier 4 simply fails
# and the bot returns "all AI models offline" once Tiers 1-3 are exhausted —
# it will not silently start charging you. Only set this if you deliberately
# want a paid fallback.
# Get from: https://openrouter.ai
OPENROUTER_API_KEY=

# Web search — primary (1,000 req/month free)
# Get from: https://www.tavily.com
TAVILY_API_KEY=your_tavily_api_key

# Web search — fallback (2,500 req lifetime free)
# Get from: https://serper.dev
SERPER_API_KEY=your_serper_api_key
